%{
#include "y.tab.h"
%}

%%
[0-9]+      { yylval = atoi(yytext); return NUM; }
[ \t]       ;   /* ignore spaces */
\n          { return 0; }
.           { return yytext[0]; }
%%

%{
#include <stdio.h>
#include <stdlib.h>

void yyerror(const char *s);
int yylex();
%}

%token NUM

%%

input:
    E { printf("Result = %d\n", $1); }
    ;

E:
    E '+' T { $$ = $1 + $3; }
  | E '-' T { $$ = $1 - $3; }
  | T       { $$ = $1; }
  ;

T:
    T '*' F { $$ = $1 * $3; }
  | T '/' F { $$ = $1 / $3; }
  | F       { $$ = $1; }
  ;

F:
    '(' E ')' { $$ = $2; }
  | NUM       { $$ = $1; }
  ;

%%

void yyerror(const char *s)
{
    printf("Invalid Expression\n");
}

int main()
{
    printf("Enter Expression:\n");
    yyparse();
    return 0;
}