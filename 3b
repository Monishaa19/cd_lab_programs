%{
#include "y.tab.h"
%}

%%
"int"       { return TYPE; }
"float"     { return TYPE; }
"char"      { return TYPE; }

"return"    { return RETURN; }

[a-zA-Z_][a-zA-Z0-9_]*   { return ID; }
[0-9]+                   { return NUM; }

"("         { return '('; }
")"         { return ')'; }
"{"         { return '{'; }
"}"         { return '}'; }
","         { return ','; }
";"         { return ';'; }

[ \t\n]     ;   /* ignore whitespace */

.           { return yytext[0]; }
%%

%{
#include <stdio.h>
#include <stdlib.h>

void yyerror(const char *s);
int yylex();
%}

%token TYPE ID NUM RETURN

%%

S:
    TYPE ID '(' PARAMS ')' '{' BODY '}'
    { printf("Valid Function Definition\n"); }
    ;

PARAMS:
    PARAM_LIST
  | 
  ;

PARAM_LIST:
    PARAM
  | PARAM ',' PARAM_LIST
  ;

PARAM:
    TYPE ID
  ;

BODY:
    RETURN_STMT
  ;

RETURN_STMT:
    RETURN ID ';'
  | RETURN NUM ';'
  ;

%%

void yyerror(const char *s)
{
    printf("Invalid Function Definition\n");
}

int main()
{
    printf("Enter Function:\n");
    yyparse();
    return 0;
}